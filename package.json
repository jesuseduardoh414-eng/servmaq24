{
  "name": "servmaq-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Plataforma e-commerce B2B (maquinaria/médico) — migración de scava.website a Next.js + NestJS + Prisma",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @servmaq/db generate",
    "db:pull": "pnpm --filter @servmaq/db pull"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  }
}
