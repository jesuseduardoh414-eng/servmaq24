# === API NestJS (@maqserv/api) ===
# En LOCAL, la API toma estos valores de packages/db/.env (Prisma lo carga al arrancar).
# En PRODUCCIÓN se configuran en el panel de Render (ver render.yaml y DEPLOY.md).

# --- Base de datos (Supabase Postgres) ---
#
# OJO CON EL PUERTO — esto vale 4x en velocidad (medido):
#   :6543 = pooler en modo TRANSACCIÓN (+ ?pgbouncer=true). Es para serverless (Vercel,
#           Lambda), donde hay miles de conexiones efímeras. Prisma, ahí, envuelve CADA
#           consulta en BEGIN + DEALLOCATE ALL + SELECT + COMMIT = 4 viajes de red por
#           consulta. Con la BD a ~100 ms, una lectura tonta costaba ~500 ms.
#   :5432 = pooler en modo SESIÓN. Es lo correcto AQUÍ: esta API es un proceso Node
#           persistente (Render), no serverless. Prisma usa la conexión normal ⇒
#           1 viaje por consulta. Medido: 513 ms → 103 ms.
#
# `connection_limit` explícito: sin él Prisma abre `nº CPUs × 2 + 1`, que en el host de
# Render puede dispararse y agotar el pooler.
#
# Si algún día la API se mueve a serverless (Vercel/Lambda), hay que VOLVER a :6543 con
# ?pgbouncer=true — en ese caso el modo sesión agotaría las conexiones.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?connection_limit=10&pool_timeout=20"

# Migraciones/introspección (prisma migrate, db pull). Sin pool.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase (Auth + Storage, service_role) ---
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_ANON_KEY="<anon key>"
SUPABASE_SERVICE_KEY="<service_role key — SECRETO>"
IMAGE_BASE_URL="https://<ref>.supabase.co/storage/v1/object/public/media"

# --- URLs públicas ---
SITE_URL="https://tu-tienda.vercel.app"          # tienda (back_urls de pago, revalidación)
API_PUBLIC_URL="https://servmaq-api.onrender.com" # esta misma API (webhook de MercadoPago)

# --- CORS: dominios permitidos separados por coma (web y admin de Vercel) ---
# OBLIGATORIO en producción: si falta, la API no arranca (antes caía en silencio a
# un patrón de localhost, que en producción no protege nada).
CORS_ORIGINS="https://tu-tienda.vercel.app,https://tu-admin.vercel.app"

# --- Límite de peticiones: IP real del visitante ---
# El navegador nunca llama a esta API (pasa por Next), así que todas las peticiones
# llegan con la IP de Vercel. Web y admin mandan la IP real del visitante en
# `x-client-ip`, firmada con este secreto, para que el límite cuente por persona y no
# por servidor. Mismo valor aquí y en web/admin. Si se deja vacío, la API confía en el
# header sin firma (funciona, pero un atacante puede inventárselo y saltarse el límite).
PROXY_SECRET="<cadena aleatoria larga — mismo valor en web y admin>"

# --- Pagos ---
MP_ACCESS_TOKEN="<access token de MercadoPago>"

# --- Revalidación on-demand del sitio Next (mismo valor que en la web) ---
REVALIDATE_SECRET="<cadena aleatoria larga>"

# --- Opcionales (CRM Perfex / cálculo de flete) ---
# PERFEX_URL=""
# PERFEX_TOKEN=""
# GOOGLE_DISTANCE_MATRIX_API_KEY=""

# PORT lo inyecta la plataforma; en local usa 4000 por defecto.
