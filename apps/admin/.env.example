# === Panel de administración (@maqserv/admin, Next.js) ===
# En LOCAL copia este archivo a .env.local. En PRODUCCIÓN se configuran en
# Vercel → Project Settings → Environment Variables.

# URL de la API NestJS (server-side).
API_URL="https://servmaq-api.onrender.com"

# URL del sitio público. Solo se usa para enlazar hacia él (ver la tienda de un
# vendedor). Si falta, en local cae a http://localhost:3000.
SITE_URL="https://scava.website"

# Firma con la que le pasamos a la API la IP real de quien entra (para que el límite de
# intentos de login cuente por persona y no por servidor). Mismo valor que en la API.
PROXY_SECRET="<cadena aleatoria larga — mismo valor que en la API>"
