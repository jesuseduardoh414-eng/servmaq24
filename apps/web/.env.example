# === Tienda (@maqserv/web, Next.js) ===
# En LOCAL copia este archivo a .env.local. En PRODUCCIÓN se configuran en
# Vercel → Project Settings → Environment Variables.

# URL de la API NestJS (server-side; NO lleva NEXT_PUBLIC porque el navegador
# nunca llama a la API directo: Next hace de proxy del lado del servidor).
API_URL="https://servmaq-api.onrender.com"

# Supabase público (el navegador usa la anon key; es pública por diseño).
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon key>"

# URL pública del sitio (sitemap.xml, robots.txt, canonical).
SITE_URL="https://tu-tienda.vercel.app"

# Revalidación on-demand (mismo valor que REVALIDATE_SECRET de la API).
REVALIDATE_SECRET="<cadena aleatoria larga>"
