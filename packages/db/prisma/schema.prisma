model messages {
  id              Int       @id @default(autoincrement())
  conversation_id Int
  message         String    @db.Text
  sent_user       Int?
  recieved_user   Int?
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

model migrations {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  migration String
  batch     Int
}

model mirrormx_customer_chat_data {
  id    BigInt  @id @default(autoincrement())
  type  String  @db.VarChar(255)
  key   String  @db.VarChar(255)
  value String? @db.Text

  @@index([key], map: "key")
  @@index([type], map: "type")
}

model mirrormx_customer_chat_message {
  id             BigInt   @id @default(autoincrement())
  from_id        BigInt
  to_id          BigInt
  body           String   @db.Text
  datetime       DateTime @default(now()) @db.Timestamp(0)
  talk_id        BigInt
  is_new         String   @default("y") @db.Char(1)
  from_user_info String   @db.Text
  to_user_info   String   @db.Text
}

model mirrormx_customer_chat_user {
  id            BigInt   @id @default(autoincrement())
  name          String   @db.Char(32)
  mail          String   @db.Char(64)
  password      String   @db.Char(255)
  image         String?  @db.Char(255)
  info          String?  @db.Text
  roles         String?  @db.Char(128)
  last_activity DateTime @default(dbgenerated("('0000-00-00 00:00:00')")) @db.Timestamp(0)
