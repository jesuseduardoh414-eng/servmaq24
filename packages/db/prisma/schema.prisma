generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model about_sections {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  type       String
  title      String?
  content    String    @db.Text
  image      String?
  order      Int       @default(0)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model admin_user_conversations {
  id         Int       @id @default(autoincrement())
  subject    String
  user_id    Int
  message    String    @db.Text
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model admin_user_messages {
  id              Int       @id @default(autoincrement())
  conversation_id Int
  message         String    @db.Text
  user_id         Int?
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
}

model admins {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  name           String
  email          String    @unique(map: "admins_email_unique")
  phone          String
  role           String    @default("Administrator")
  photo          String?
  password       String
  status         Int       @default(1) @db.TinyInt
  remember_token String?   @db.VarChar(100)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
}

model advertises {
  id     Int     @id @default(autoincrement())
  type   String
  photo  String?
  alt    String?
  url    String?
  script String? @db.Text
  size   String
  clicks Int     @default(0)
  status Int     @default(0) @db.TinyInt
}

model baners_derechos {
  id    Int     @id @default(autoincrement())
  top1l String? @db.VarChar(250)
  top1  String? @db.VarChar(250)
  top2l String? @db.VarChar(250)
  top2  String? @db.VarChar(250)
}

model banners {
  id       Int     @id @default(autoincrement()) @db.UnsignedInt
  top1     String?
  top2     String?
  top3     String?
  top4     String?
  bottom1  String?
  bottom2  String?
  top1l    String?
  top2l    String?
  top3l    String?
  top4l    String?
  bottom1l String?
  bottom2l String?
  top5     String? @db.VarChar(250)
  top5l    String? @db.VarChar(250)
}

model benefits {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  title       String
  description String?   @db.Text
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
}

model blogs {
  id               Int       @id @default(autoincrement()) @db.UnsignedInt
  title            String
  details          String    @db.Text
  photo            String?
  source           String
  views            Int       @default(0)
  status           Int       @default(1) @db.TinyInt
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)
  meta_tag         String?   @db.Text
  meta_description String?   @db.Text
}

model brands {
  id    Int     @id @default(autoincrement()) @db.UnsignedInt
  photo String
  url   String?
}

model categorias_populares {
  id    Int     @id @default(autoincrement())
  top1l String? @db.VarChar(250)
  top2l String? @db.VarChar(250)
  top3l String? @db.VarChar(250)
  top4l String? @db.VarChar(250)
  top5l String? @db.VarChar(250)
  top6l String? @db.VarChar(250)
  top7l String? @db.VarChar(250)
  top8l String? @db.VarChar(250)
  top1  String? @db.VarChar(250)
  top2  String? @db.VarChar(250)
  top3  String? @db.VarChar(250)
  top4  String? @db.VarChar(250)
  top5  String? @db.VarChar(250)
  top6  String? @db.VarChar(250)
  top7  String? @db.VarChar(250)
  top8  String? @db.VarChar(250)
}

model categories {
  id       Int     @id @default(autoincrement()) @db.UnsignedInt
  cat_name String  @db.VarChar(100)
  cat_slug String  @unique(map: "bloodgroups_slug_unique")
  status   Int     @default(1) @db.TinyInt
  photo    String?

  @@index([id], map: "id")
}

model childcategories {
  id             Int    @id @default(autoincrement()) @db.UnsignedInt
  subcategory_id Int    @db.UnsignedInt
  child_name     String
  child_slug     String
  status         Int    @default(1) @db.TinyInt
}

model comments {
  id         Int      @id @default(autoincrement())
  user_id    Int      @db.UnsignedInt
  product_id Int      @db.UnsignedInt
  text       String   @db.Text
  created_at DateTime @default(dbgenerated("('0000-00-00 00:00:00')")) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)
  rating     Int?     @default(5)
}

model conversations {
  id            Int       @id @default(autoincrement())
  subject       String
  sent_user     Int
  recieved_user Int
  message       String    @db.Text
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)
}

model counters {
  id           Int           @id @default(autoincrement())
  type         counters_type @default(referral)
  referral     String?       @db.VarChar(255)
  total_count  Int           @default(0)
  todays_count Int           @default(0)
  today        DateTime?     @db.Date
}

model coupons {
  id         Int      @id @default(autoincrement())
  code       String
  type       Int      @db.TinyInt
  price      Float
  times      String?
  used       Int      @default(0) @db.UnsignedInt
  status     Int      @default(1) @db.TinyInt
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
}

model currencies {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(30)
  sign       String  @db.VarChar(10)
  value      Float
  is_default Boolean @default(false)
}

model direcciones {
  id         Int     @id @default(autoincrement())
  direccion  String? @db.VarChar(250)
  updated_at String? @db.VarChar(250)
  created_at String? @db.VarChar(250)
  Id_user    String? @db.VarChar(250)
}

model distribusions {
  id     Int     @id @default(autoincrement()) @db.UnsignedInt
  Nombre String? @db.VarChar(250)
  photo  String
  url    String?
}

model email_templates {
  id            Int     @id @default(autoincrement())
  email_type    String? @db.VarChar(255)
  email_subject String? @db.MediumText
  email_body    String? @db.LongText
  status        Int     @default(1)
}

model faqs {
  id    Int    @id @default(autoincrement()) @db.UnsignedInt
  title String
  text  String @db.Text
}

model favorite_sellers {
  id        Int @id @default(autoincrement())
  user_id   Int
  vendor_id Int
}

model galleries {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  product_id Int?      @db.UnsignedInt
  photo      String
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

